{
  "name": "@rubiks-cube-solver/rubiks-cube",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Rubik's Cube visualization package for Rubik's Cube Solver",
  "license": "MIT",
  "keywords": [
    "rubik's cube",
    "twisty puzzle",
    "3x3",
    "renderer",
    "threejs"
  ],
  "exports": {
    "./view": {
      "types": "./src/puzzles/cube/element/index.ts",
      "default": "./src/puzzles/cube/element/index.ts"
    },
    "./player": {
      "types": "./src/puzzles/cube/player/index.ts",
      "default": "./src/puzzles/cube/player/index.ts"
    },
    "./three": {
      "types": "./src/puzzles/cube/three/index.ts",
      "default": "./src/puzzles/cube/three/index.ts"
    },
    "./controller": {
      "types": "./src/puzzles/cube/controller/index.ts",
      "default": "./src/puzzles/cube/controller/index.ts"
    },
    "./core": {
      "types": "./src/puzzles/cube/core/index.ts",
      "default": "./src/puzzles/cube/core/index.ts"
    },
    "./state": {
      "types": "./src/puzzles/cube/state/index.ts",
      "default": "./src/puzzles/cube/state/index.ts"
    },
    "./puzzles/cube": {
      "types": "./src/puzzles/cube/index.ts",
      "default": "./src/puzzles/cube/index.ts"
    },
    "./puzzles/pyraminx": {
      "types": "./src/puzzles/pyraminx/index.ts",
      "default": "./src/puzzles/pyraminx/index.ts"
    },
    "./pyraminx": {
      "types": "./src/puzzles/pyraminx/index.ts",
      "default": "./src/puzzles/pyraminx/index.ts"
    },
    "./puzzles/megaminx": {
      "types": "./src/puzzles/megaminx/index.ts",
      "default": "./src/puzzles/megaminx/index.ts"
    },
    "./megaminx": {
      "types": "./src/puzzles/megaminx/index.ts",
      "default": "./src/puzzles/megaminx/index.ts"
    }
  },
  "scripts": {
    "playground": "vite --host 0.0.0.0 --port 5174 ./playground",
    "build:types": "tsc",
    "check": "biome check .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "lint": "biome lint . --error-on-warnings",
    "watch:types": "tsc --watch",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --passWithNoTests"
  },
  "dependencies": {
    "gsap": "^3.14.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.7"
  }
}
