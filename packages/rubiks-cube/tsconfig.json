{
  "compilerOptions": {
    "module": "esnext",
    "skipLibCheck": true,
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "lib": ["DOM", "ESNext"]
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "tests"]
}
