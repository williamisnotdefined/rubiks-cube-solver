  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "npm run build:types -w @rubiks-cube-solver/rubiks-cube && tsc -b && vite build && vite build --ssr src/main/ssg.tsx --outDir dist-ssr --emptyOutDir && node ../../scripts/seo/generate-static-assets.mjs",
    "lint": "biome lint . --error-on-warnings && eslint . --max-warnings 0",
    "format": "biome format . --write",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "storybook": "storybook dev -p 6006 --host 0.0.0.0",
    "storybook:build": "storybook build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "VITEST_COVERAGE=true vitest run --coverage --passWithNoTests"
