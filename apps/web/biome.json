{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "src/**/*",
      ".storybook/**/*",
      "biome.json",
      "index.html",
      "package.json",
      "tsconfig*.json",
      "vite.config.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "noAriaHiddenOnFocusable": "off",
        "noLabelWithoutControl": "off",
        "noNoninteractiveTabindex": "off",
        "useAriaPropsSupportedByRole": "off",
        "useSemanticElements": "off"
      },
      "complexity": {
        "noUselessEmptyExport": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": {
          "level": "error",
          "options": {
            "reportUnnecessaryDependencies": false
          }
        },
        "useHookAtTopLevel": "error"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "useIterableCallbackReturn": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off",
        "useComponentExportOnlyModules": {
          "level": "error",
          "options": {
            "allowConstantExport": true,
            "allowExportNames": [
              "AlertDialog",
              "AlertDialogAction",
              "AlertDialogCancel",
              "AlertDialogDescription",
              "AlertDialogTitle",
              "Dialog",
              "DialogClose",
              "DialogDescription",
              "DialogTitle",
              "DialogTrigger",
              "Popover",
              "PopoverAnchor",
              "PopoverTrigger",
              "Select",
              "SelectGroup",
              "SelectValue"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/**/*.stories.tsx", "src/**/__tests__/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "useComponentExportOnlyModules": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
