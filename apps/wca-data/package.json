{
  "name": "@rubiks-cube-solver/wca-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "db:migrate": "tsx src/db/migrate.ts",
    "dev:api": "tsx watch src/api/main.ts",
    "dev:worker": "tsx watch src/worker/main.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/api/main.js",
    "start:worker": "node dist/worker/main.js",
    "sync:once": "tsx src/cli/main.ts sync-once",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "fastify": "5.10.0",
    "pg": "8.22.0",
    "pg-boss": "12.25.1",
    "pg-copy-streams": "7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.9.0",
    "yauzl": "3.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "8.20.0",
    "@types/pg-copy-streams": "1.2.5",
    "@types/yauzl": "3.4.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
