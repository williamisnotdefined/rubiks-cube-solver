{
  "name": "rubiks-cube-solver",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run pruning:native && concurrently -k -n api,web -c blue,green \"npm run api:dev\" \"npm run web:dev\"",
    "web:dev": "npm run dev -w @rubiks-cube-solver/web",
    "api:dev": "cargo run -p rubiks-cube-solver-api",
    "api:test": "cargo test -p rubiks-cube-solver-api",
    "build": "npm run build -w @rubiks-cube-solver/web",
    "ai:check": "node scripts/ai/sync-routes.mjs --check",
    "ai:sync": "node scripts/ai/sync-routes.mjs",
    "lint": "npm run ai:check && npm run lint -w @rubiks-cube-solver/web",
    "format": "npm run ai:sync",
    "preview": "npm run preview -w @rubiks-cube-solver/web",
    "pretest:e2e": "cargo run --quiet -p cube-engine --bin generate_pruning_tables -- --output crates/cube-engine/pruning-tables --phase1-max-depth 8 --phase2-max-depth 10 && npm run build",
    "test:e2e": "playwright test",
    "pruning:native": "cargo run --quiet -p cube-engine --bin generate_pruning_tables -- --output crates/cube-engine/pruning-tables --phase1-max-depth 8 --phase2-max-depth 10",
    "pruning:report": "cargo run --quiet -p cube-engine --bin pruning_table_report",
    "pdb:corner": "cargo run --quiet -p cube-engine --bin generate_corner_pdb -- --output crates/cube-engine/pruning-tables/corner-pattern-database.rpdb --max-depth 8",
    "pdb:corner:deep": "cargo run --quiet -p cube-engine --bin generate_corner_pdb -- --output crates/cube-engine/pruning-tables/corner-pattern-database.rpdb --max-depth 11",
    "pdb:edge": "cargo run --quiet -p cube-engine --bin generate_edge_pdb -- --output-dir crates/cube-engine/pruning-tables --max-depth 6 --pattern all",
    "pdb:edge:deep": "cargo run --quiet -p cube-engine --bin generate_edge_pdb -- --output-dir crates/cube-engine/pruning-tables --max-depth 8 --pattern all",
    "dataset:solver": "cargo run --quiet -p cube-engine --bin generate_solver_dataset -- --count 64 --max-scramble-depth 12 --solver-max-depth 30 --solver-max-nodes 1000000 --solver-label-mode generated-two-phase-quality",
    "dataset:solver:1k": "cargo run --quiet -p cube-engine --bin generate_solver_dataset -- --count 1000 --output datasets/generated/solver-training-1k-depth12-quality.jsonl --max-scramble-depth 12 --solver-max-depth 30 --solver-max-nodes 1000000 --solver-label-mode generated-two-phase-quality",
    "dataset:solver:1k:depth25": "cargo run --quiet -p cube-engine --bin generate_solver_dataset -- --count 1000 --output datasets/generated/solver-training-1k-depth25-quality.jsonl --max-scramble-depth 25 --solver-max-depth 30 --solver-max-nodes 1000000 --solver-label-mode generated-two-phase-quality",
    "dataset:solver:10k": "cargo run --quiet -p cube-engine --bin generate_solver_dataset -- --count 10000 --output datasets/generated/solver-training-10k-depth12-quality.jsonl --max-scramble-depth 12 --solver-max-depth 30 --solver-max-nodes 1000000 --solver-label-mode generated-two-phase-quality",
    "ml:solver-smoke": "npm run dataset:solver && python -m ml.train_value_baseline --dataset datasets/generated/solver-training.jsonl --epochs 1 --seed 0 --output ml/outputs/solver-value-baseline --inference-repeats 1",
    "ml:solver:1k": "python -m ml.train_value_baseline --dataset datasets/generated/solver-training-1k-depth12-quality.jsonl --epochs 20 --seed 0 --output ml/outputs/solver-value-1k-depth12-quality --inference-repeats 10",
    "ml:solver:1k:depth25": "python -m ml.train_value_baseline --dataset datasets/generated/solver-training-1k-depth25-quality.jsonl --epochs 20 --seed 0 --output ml/outputs/solver-value-1k-depth25-quality --inference-repeats 10",
    "ml:solver:10k": "python -m ml.train_value_baseline --dataset datasets/generated/solver-training-10k-depth12-quality.jsonl --epochs 20 --seed 0 --output ml/outputs/solver-value-10k-depth12-quality --inference-repeats 10",
    "product:gate": "npm run ai:check && cargo fmt --check && cargo test && cargo clippy --all-targets --all-features -- -D warnings && cargo run --quiet -p cube-engine --bin generate_pruning_tables -- --output crates/cube-engine/pruning-tables --phase1-max-depth 8 --phase2-max-depth 10 && npm run build && npm run lint -w @rubiks-cube-solver/web && npm run test:e2e && python -m pytest ml && python -m ml.train_value_baseline --dataset datasets/fixtures/small.jsonl --epochs 1 --seed 0 --output ml/outputs/value-baseline --inference-repeats 1 && cargo run --quiet -p cube-engine --bin solver_quality_report && cargo run --quiet -p cube-engine --bin solver_quality_report -- --hybrid-value-outputs ml/outputs/value-baseline/value_outputs.tsv && npm run solver:real-scrambles:gate",
    "solver:bench": "cargo run --quiet -p cube-engine --bin solver_quality_report",
    "solver:bench:hybrid-model": "cargo run --quiet -p cube-engine --bin solver_quality_report -- --hybrid-value-model ml/outputs/solver-value-1k-depth12-quality/model.json",
    "solver:real-scrambles": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-quality --max-depth 30 --max-nodes 1000",
    "solver:real-scrambles:gate": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-quality --max-depth 30 --max-nodes 10000000 --require-success",
    "solver:real-scrambles:deep20": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-quality --max-depth 30 --max-nodes 50000000 --require-success --require-max-solution-len 20",
    "solver:real-scrambles:multiprobe": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-multiprobe --max-depth 30 --max-nodes 10000000",
    "solver:real-scrambles:corner-pdb": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy optimal-bounded-corner-pdb --max-depth 30 --max-nodes 10000000",
    "solver:short16": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-quality --max-depth 30 --max-nodes 10000000 --generated-count 20 --generated-seed 0 --generated-scramble-depth 16",
    "solver:short16:corner-pdb": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy optimal-bounded-corner-pdb --max-depth 30 --max-nodes 10000000 --generated-count 5 --generated-seed 0 --generated-scramble-depth 16",
    "solver:short16:pdb16": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy optimal-bounded-pdb16 --max-depth 30 --max-nodes 10000000 --generated-count 5 --generated-seed 0 --generated-scramble-depth 16",
    "solver:short16:multiprobe": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-multiprobe --max-depth 30 --max-nodes 10000000 --generated-count 5 --generated-seed 0 --generated-scramble-depth 16",
    "solver:short16:api-budget": "cargo run --quiet -p cube-engine --bin solver_real_scramble_report -- --strategy generated-two-phase-quality --max-depth 30 --max-nodes 25000000 --generated-count 20 --generated-seed 0 --generated-scramble-depth 16",
    "roadmap:check": "roadrunner check --roadmap roadmap.md",
    "roadmap:cleanup": "roadrunner cleanup --roadmap roadmap.md",
    "roadmap:next": "roadrunner next --roadmap roadmap.md",
    "roadmap:plan": "roadrunner plan --roadmap roadmap.md",
    "roadmap:run": "roadrunner run --roadmap roadmap.md",
    "roadmap:run:long": "ROADRUNNER_PROVIDER_TIMEOUT_MS=0 ROADRUNNER_VERIFY_TIMEOUT_MS=0 ROADRUNNER_AUTO_RESTART_IDLE_MS=0 ROADRUNNER_MAX_AUTO_RESTARTS_PER_STEP=0 roadrunner run --roadmap roadmap.md --max-steps 999",
    "roadmap:status": "roadrunner status --roadmap roadmap.md"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1"
  }
}
